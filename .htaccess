php_value date.timezone 'America/Chicago'


# DO NOT REMOVE THIS LINE AND THE LINES BELOW SSL_REDIRECT:johnamorris.org
RewriteEngine on
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} ^johnamorris.org$
RewriteRule (.*) https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# DO NOT REMOVE THIS LINE AND THE LINES ABOVE SSL_REDIRECT:johnamorris.org

